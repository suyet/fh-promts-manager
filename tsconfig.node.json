{
  "compilerOptions": {
    "composite": true,
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "outDir": ".superpowers/tsc-node",
    "skipLibCheck": true,
    "tsBuildInfoFile": ".superpowers/tsc-node/tsconfig.node.tsbuildinfo",
    "types": ["node"],
    "strict": true
  },
  "include": ["vite.config.ts", "vitest.config.ts"]
}
